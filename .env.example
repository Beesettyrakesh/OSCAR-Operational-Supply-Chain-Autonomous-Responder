# Copy this file to `.env` and fill in real values.

# --- Reasoning core (Google Gen AI) ---
# Your Gemini API key. Leave EMPTY ("") to run the deterministic OFFLINE planner (zero cost).
GEMINI_API_KEY=YOUR_API_KEY
# Model id for the Incident Commander + Supplier-Persona. Default: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# --- Negotiation sub-graph ---
# 'llm' (live Supplier-Persona LLM) or 'deterministic' (scripted, zero-cost offline tests).
VENDOR_MODE=llm

# --- Day-4 guardrail / demo knobs (all optional; sensible defaults in code) ---
# Delegated spend-authority limit in USD (fixed policy). Default 20000.
SPEND_AUTHORITY_LIMIT_USD=20000
# Order quantity (per-incident variable). 300 -> ~$13.2k auto-approve; 500 -> ~$22k HITL. Default 500.
ORDER_QUANTITY=500
# Human-in-the-loop channel: cli | auto_approve | auto_reject. Default cli.
HITL_MODE=cli
